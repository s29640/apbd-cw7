@model MiniHelpdesk.ViewModels.CreateTicketViewModel

@{
    ViewData["Title"] = "Create Ticket";
}

<h1>Create Ticket</h1>

<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly"
         class="text-danger">
    </div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>

        <input asp-for="Title"
               class="form-control" />

        <span asp-validation-for="Title"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description"
               class="form-label"></label>

        <textarea asp-for="Description"
                  rows="4"
                      class="form-control">
        </textarea>

            <span asp-validation-for="Description"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Author"
                   class="form-label"></label>

            <input asp-for="Author"
                   class="form-control" />

            <span asp-validation-for="Author"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FirstCommentContent"
                   class="form-label"></label>

            <textarea asp-for="FirstCommentContent"
                      rows="5"
                          class="form-control">
        </textarea>

                <span asp-validation-for="FirstCommentContent"
                      class="text-danger"></span>
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Save
            </button>

            <a asp-action="Index"
                   class="btn btn-secondary">
                Cancel
            </a>

        </form>

        @section Scripts
        {
            <partial name="_ValidationScriptsPartial" />
        }